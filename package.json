{
  "name": "bodhibeats",
  "productName": "BodhiBeats",
  "version": "1.0.0",
  "description": "沉浸式移动音乐播放器，融合粒子视觉、歌词舞台和 3D 歌单架。",
  "author": "BodhiBeats",
  "main": "desktop/main.js",
  "private": true,
  "scripts": {
    "start": "node server.js",
    "build:android": "npx cap sync android && cd android && ./gradlew assembleDebug"
  },
  "build": {
    "appId": "com.bodhibeats.app",
    "productName": "BodhiBeats",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "desktop/**/*",
      "public/**/*",
      "build/**/*",
      "server.js",
      "dj-analyzer.js",
      "package.json"
    ],
    "asar": false
  },
  "mineradio": {
    "update": {
      "provider": "github",
      "owner": "ComicRogers",
      "repo": "BodhiBeats"
    }
  },
  "dependencies": {
    "gsap": "^3.15.0",
    "mpg123-decoder": "^1.0.3",
    "NeteaseCloudMusicApi": "^4.32.0"
  }
}
